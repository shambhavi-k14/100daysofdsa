#include <stdio.h>

int integerSqrt(int x) {
    int low = 0, high = x;
    int ans = 0;

    while (low <= high) {
        int mid = low + (high - low) / 2;

        // Avoid overflow using long long
        long long square = (long long)mid * mid;

        if (square <= x) {
            ans = mid;        // possible answer
            low = mid + 1;    // try larger value
        } else {
            high = mid - 1;   // try smaller value
        }
    }

    return ans;
}

int main() {
    int x;

    printf("Enter number: ");
    scanf("%d", &x);

    int result = integerSqrt(x);
    printf("Integer square root: %d\n", result);

    return 0;
}
