#include <stdio.h>

#define MAX 1000

int maxLen(int arr[], int n) {
    int sum = 0, maxLength = 0;

    // Hash map using array (for simplicity)
    int hash[2 * MAX] = {0}; // offset for negative sums
    int visited[2 * MAX] = {0};

    int offset = MAX;

    for (int i = 0; i < n; i++) {
        sum += arr[i];

        // Case 1: sum = 0
        if (sum == 0) {
            maxLength = i + 1;
        }

        // Case 2: sum seen before
        if (visited[sum + offset]) {
            int prevIndex = hash[sum + offset];
            int length = i - prevIndex;
            if (length > maxLength)
                maxLength = length;
        } else {
            hash[sum + offset] = i;
            visited[sum + offset] = 1;
        }
    }

    return maxLength;
}

int main() {
    int arr[] = {1, -1, 3, 2, -2, -3, 3};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Longest subarray length: %d\n", maxLen(arr, n));

    return 0;
}
