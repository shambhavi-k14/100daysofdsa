#include <stdio.h>
#include <limits.h>

#define MAX 100

// Find vertex with minimum key
int minKey(int key[], int visited[], int n) {
    int min = INT_MAX, minIndex = -1;

    for (int i = 0; i < n; i++) {
        if (!visited[i] && key[i] < min) {
            min = key[i];
            minIndex = i;
        }
    }
    return minIndex;
}

// Prim's Algorithm
int primMST(int graph[MAX][MAX], int n) {
    int key[MAX], visited[MAX];
    int totalWeight = 0;

    // Initialize
    for (int i = 0; i < n; i++) {
        key[i] = INT_MAX;
        visited[i] = 0;
    }

    key[0] = 0; // start from vertex 0

    for (int i = 0; i < n; i++) {
        int u = minKey(key, visited, n);
        visited[u] = 1;

        totalWeight += key[u];

        // Update adjacent vertices
        for (int v = 0; v < n; v++) {
            if (graph[u][v] && !visited[v] && graph[u][v] < key[v]) {
                key[v] = graph[u][v];
            }
        }
    }

    return totalWeight;
}

// Main
int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int graph[MAX][MAX];

    printf("Enter adjacency matrix (0 if no edge):\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }

    int result = primMST(graph, n);
    printf("Total weight of MST: %d\n", result);

    return 0;
}
