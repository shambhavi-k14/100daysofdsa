#include <stdio.h>

char firstRepeated(char *s) {
    int visited[26] = {0};

    for (int i = 0; s[i] != '\0'; i++) {
        int index = s[i] - 'a';

        if (visited[index] == 1) {
            return s[i]; // first repeated character
        }

        visited[index] = 1;
    }

    return '\0'; // no repeated character
}

int main() {
    char s[100];

    printf("Enter string: ");
    scanf("%s", s);

    char result = firstRepeated(s);

    if (result != '\0')
        printf("First repeated character: %c\n", result);
    else
        printf("No repeated character found\n");

    return 0;
}
