#include <stdio.h>

// Find maximum element
int findMax(int arr[], int n) {
    int max = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] > max)
            max = arr[i];
    }
    return max;
}

// Find sum of array
int findSum(int arr[], int n) {
    int sum = 0;
    for(int i = 0; i < n; i++) {
        sum += arr[i];
    }
    return sum;
}

// Check feasibility
int isPossible(int arr[], int n, int k, int maxTime) {
    int painters = 1;
    int currTime = 0;

    for(int i = 0; i < n; i++) {

        // Single board exceeds limit
        if(arr[i] > maxTime)
            return 0;

        if(currTime + arr[i] > maxTime) {
            painters++;
            currTime = arr[i];

            if(painters > k)
                return 0;
        } else {
            currTime += arr[i];
        }
    }
    return 1;
}

// Main logic
int minTime(int arr[], int n, int k) {
    int low = findMax(arr, n);
    int high = findSum(arr, n);
    int ans = high;

    while(low <= high) {
        int mid = (low + high) / 2;

        if(isPossible(arr, n, k, mid)) {
            ans = mid;
            high = mid - 1;  // try smaller
        } else {
            low = mid + 1;   // increase time
        }
    }
    return ans;
}

int main() {
    int n, k;

    printf("Enter number of boards: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter board lengths:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter number of painters: ");
    scanf("%d", &k);

    int result = minTime(arr, n, k);

    printf("Minimum time required = %d\n", result);

    return 0;
}
