#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAX 100

// Comparator for sorting strings
int compare(const void *a, const void *b) {
    return strcmp((char *)a, (char *)b);
}

int main() {
    int n;
    char votes[MAX][50];

    printf("Enter number of votes: ");
    scanf("%d", &n);

    printf("Enter candidate names:\n");
    for (int i = 0; i < n; i++) {
        scanf("%s", votes[i]);
    }

    // Step 1: Sort names
    qsort(votes, n, sizeof(votes[0]), compare);

    // Step 2: Count frequencies
    int maxCount = 1, count = 1;
    char winner[50];
    strcpy(winner, votes[0]);

    for (int i = 1; i < n; i++) {
        if (strcmp(votes[i], votes[i - 1]) == 0) {
            count++;
        } else {
            count = 1;
        }

        // Update winner
        if (count > maxCount) {
            maxCount = count;
            strcpy(winner, votes[i]);
        }
        else if (count == maxCount) {
            if (strcmp(votes[i], winner) < 0) {
                strcpy(winner, votes[i]);
            }
        }
    }

    printf("Winner: %s\nVotes: %d\n", winner, maxCount);

    return 0;
}
